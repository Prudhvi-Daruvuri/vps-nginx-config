# RentCamPro - rentcampro.ofoundation.xyz
# HTTP → HTTPS redirect (Certbot will add HTTPS block below)
server {
    listen 80;
    server_name rentcampro.ofoundation.xyz;

    # Certbot will manage SSL certificates and add HTTPS config
    # Run: certbot --nginx -d rentcampro.ofoundation.xyz

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS server (Certbot will populate ssl_certificate paths)
server {
    listen 443 ssl;
    server_name rentcampro.ofoundation.xyz;

    # SSL managed by Certbot - do not edit these lines manually
    # ssl_certificate /etc/letsencrypt/live/rentcampro.ofoundation.xyz/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/rentcampro.ofoundation.xyz/privkey.pem;
    # include /etc/letsencrypt/options-ssl-nginx.conf;
    # ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=63072000" always;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml text/javascript
               application/json application/javascript application/xml+rss;

    # Rate limiting zones (defined in nginx.conf or here)
    # limit_req_zone $binary_remote_addr zone=api_limit:10m rate=10r/s;
    # limit_req_zone $binary_remote_addr zone=general_limit:10m rate=100r/s;

    client_max_body_size 100M;

    # Backend API - proxy to Docker container on port 8000
    location /api/ {
        proxy_pass http://127.0.0.1:8000/api/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Frontend - proxy to Docker container on port 3000
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Static files caching
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$ {
        proxy_pass http://127.0.0.1:3000;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
